# =============================================================================
# ADAPTIV HEALTH - Example Environment Configuration
# =============================================================================
# Copy this file to .env and replace placeholder values.
# Never commit your real .env with production secrets.
# =============================================================================

# -----------------------------------------------------------------------------
# Database
# -----------------------------------------------------------------------------
# PostgreSQL connection string
DATABASE_URL=postgresql+psycopg://postgres:your-password@localhost:5432/adaptiv_health

# -----------------------------------------------------------------------------
# JWT / Auth
# -----------------------------------------------------------------------------
# App metadata
APP_NAME=Adaptiv Health API
APP_VERSION=1.0.0
ENVIRONMENT=development
DEBUG=true

# JWT signing and token lifetime
SECRET_KEY=replace-with-32-plus-char-random-secret
ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=30
REFRESH_TOKEN_EXPIRE_DAYS=7

# Session/login security settings
RATE_LIMIT_PER_MINUTE=60
SESSION_TIMEOUT_MINUTES=30
MAX_LOGIN_ATTEMPTS=3
LOCKOUT_DURATION_MINUTES=5

# Optional Gemini key for document extraction
# Any one of these names is accepted by backend config:
# GEMINI_API_KEY, GOOGLE_API_KEY, GOOGLE_GENERATIVE_AI_API_KEY
GEMINI_API_KEY=

# -----------------------------------------------------------------------------
# PHI Encryption
# -----------------------------------------------------------------------------
# Optional AES-256-GCM key (base64-encoded 32-byte key)
PHI_ENCRYPTION_KEY=

# -----------------------------------------------------------------------------
# SMTP / Email
# -----------------------------------------------------------------------------
# SMTP server settings (SendGrid SMTP-compatible or other provider)
SMTP_HOST=
SMTP_PORT=587
SMTP_USERNAME=
SMTP_PASSWORD=
SMTP_FROM_EMAIL=
SMTP_FROM_NAME=Adaptiv Health
SMTP_USE_TLS=true
SMTP_USE_SSL=false

# Frontend reset URL contract
FRONTEND_BASE_URL=http://localhost:3000
PASSWORD_RESET_PATH=/reset-password

# DEV ONLY: when true and SMTP is not configured, reset token is logged
PASSWORD_RESET_DEV_TOKEN_LOGGING=false

# -----------------------------------------------------------------------------
# CORS
# -----------------------------------------------------------------------------
# JSON array string of allowed origins
ALLOWED_ORIGINS=["http://localhost:3000","http://localhost:5173","http://localhost:5000"]

# -----------------------------------------------------------------------------
# AWS (Production)
# -----------------------------------------------------------------------------
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_REGION=me-central-1
S3_BUCKET_NAME=

# ECS deploy vars (used by scripts/deploy.sh)
AWS_ACCOUNT_ID=991940085325
ECS_CLUSTER=adaptivhealth-cluster
ECS_SERVICE=adaptivhealth-backend-service
CLOUDFRONT_DISTRIBUTION_ID=
