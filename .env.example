# =============================================================================
# ADAPTIV HEALTH - Environment Configuration
# =============================================================================
# Copy this file to .env and fill in the values.
# IMPORTANT: Never commit .env to Git.
# =============================================================================

# ---- Database: PostgreSQL ----
DATABASE_URL=postgresql+psycopg://user:password@host:5432/dbname

# ---- Authentication / JWT ----
SECRET_KEY=your-secret-key-here
ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=30
REFRESH_TOKEN_EXPIRE_DAYS=7

# ---- PHI Encryption Key (AES-256-GCM) ----
PHI_ENCRYPTION_KEY=your-base64-encryption-key-here

# ---- Gemini AI (Document Extraction & AI Coach) ----
GEMINI_API_KEY=your-gemini-api-key-here

# ---- Application Settings ----
ENVIRONMENT=development
DEBUG=true
APP_NAME=Adaptiv Health API
APP_VERSION=1.0.0

# ---- CORS (allowed frontend origins) ----
ALLOWED_ORIGINS=["http://localhost:3000","http://localhost:8080","http://localhost:5173"]

# ---- Rate Limiting / Security ----
RATE_LIMIT_PER_MINUTE=60
SESSION_TIMEOUT_MINUTES=30
MAX_LOGIN_ATTEMPTS=3
LOCKOUT_DURATION_MINUTES=5

# ---- AWS Config ----
AWS_REGION=ap-south-1

# ---- SMTP / Email (Password Reset) ----
SMTP_HOST=
SMTP_PORT=587
SMTP_USERNAME=
SMTP_PASSWORD=
SMTP_FROM_EMAIL=
SMTP_FROM_NAME=Adaptiv Health
SMTP_USE_TLS=true
SMTP_USE_SSL=false
FRONTEND_BASE_URL=http://localhost:3000
PASSWORD_RESET_PATH=/reset-password
PASSWORD_RESET_DEV_TOKEN_LOGGING=false
